{
  "name": "websearch-deepseek",
  "version": "1.0.0",
  "description": "通用 MCP Server — 基于 DeepSeek 原生联网搜索 API 的 Web Search 工具。适用于 Claude Code、Cursor、Continue、OpenCode 等任何支持 MCP 协议的 AI 编程助手。",
  "license": "MIT",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "web-search",
    "deepseek",
    "ai-tools",
    "ai-agent",
    "claude-code",
    "cursor",
    "opencode"
  ],
  "author": "lyumeng",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lyumeng/websearch-deepseek.git"
  },
  "homepage": "https://github.com/lyumeng/websearch-deepseek#readme",
  "bugs": {
    "url": "https://github.com/lyumeng/websearch-deepseek/issues"
  },
  "type": "module",
  "bin": {
    "websearch-deepseek": "./dist/src/mcp.js"
  },
  "exports": {
    ".": "./dist/src/mcp.js",
    "./core": "./dist/src/core.js",
    "./cli": "./dist/src/cli.js"
  },
  "types": "./dist/src/mcp.d.ts",
  "files": [
    "dist/",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "search": "npx tsx src/cli.ts search",
    "mcp": "npx tsx src/mcp.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.8.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0"
  }
}
